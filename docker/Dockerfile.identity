# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /build

# Copy solution and project files
COPY ["shared/", "shared/"]
COPY ["services/", "services/"]

# Restore and build
RUN dotnet restore "services/identity-service/IdentityService.Api/IdentityService.Api.csproj"
RUN dotnet build "services/identity-service/IdentityService.Api/IdentityService.Api.csproj" -c Release -o /app/build

# Publish stage
FROM build AS publish
RUN dotnet publish "services/identity-service/IdentityService.Api/IdentityService.Api.csproj" -c Release -o /app/publish

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=publish /app/publish .

ENV ASPNETCORE_URLS=http://+:5001
EXPOSE 5001

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD dotnet /app/HealthCheck.dll || exit 1

ENTRYPOINT ["dotnet", "IdentityService.Api.dll"]
